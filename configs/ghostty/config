theme = dark:Nvim Dark,light:Nvim Light
font-family = Menlo Regular
font-style=bold
font-size = 14
mouse-hide-while-typing = true
macos-option-as-alt = true
window-padding-balance = true
shell-integration-features=no-cursor
maximize=true
cursor-style-blink=false
cursor-style = block
adjust-cell-height = 2
adjust-cell-width = 0
cursor-color = green
split-divider-color = green

keybind = cmd+n=next_tab
keybind = cmd+p=previous_tab
keybind = cmd+[=previous_tab
keybind = cmd+]=next_tab
keybind = cmd+t=new_tab
keybind = cmd+shift+f=toggle_split_zoom

keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

keybind = cmd+down=goto_split:down
keybind = cmd+left=goto_split:left
keybind = cmd+up=goto_split:up
keybind = cmd+right=goto_split:right

keybind = cmd+0=equalize_splits
keybind = cmd+shift+up=resize_split:up,20
keybind = cmd+shift+down=resize_split:down,20
keybind = cmd+shift+left=resize_split:left,20
keybind = cmd+shift+right=resize_split:right,20
