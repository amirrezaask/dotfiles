theme = Nvim Dark
# theme = Vague
# theme = Everforest Dark Hard
# theme = Gruvbox Dark Hard

font-family = Maple Mono
font-size = 14
mouse-hide-while-typing = true
macos-option-as-alt = true
window-padding-balance = true
shell-integration-features=no-cursor
window-inherit-working-directory = false
maximize=true
cursor-style-blink=false
cursor-style = block
# adjust-cell-height = 40%
# adjust-cell-width = 0
# background=#000000
# foreground=#ffffff
cursor-color = green

split-divider-color = green
# background-opacity = 0.95
# background-blur = true

keybind = cmd+[=previous_tab
keybind = cmd+]=next_tab
keybind = cmd+shift+f=toggle_split_zoom
keybind = cmd+,=previous_tab
keybind = cmd+.=next_tab

keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

keybind = cmd+down=goto_split:down
keybind = cmd+left=goto_split:left
keybind = cmd+up=goto_split:up
keybind = cmd+right=goto_split:right

keybind = cmd+0=equalize_splits
keybind = cmd+shift+up=resize_split:up,20
keybind = cmd+shift+down=resize_split:down,20
keybind = cmd+shift+left=resize_split:left,20
keybind = cmd+shift+right=resize_split:right,20
keybind = shift+enter=text:\x1b\r
