theme = TokyoNight Moon
font-family = Fira Code
font-size = 15
mouse-hide-while-typing = true
macos-option-as-alt = true
window-padding-balance = true
shell-integration-features=no-cursor
maximize=true
cursor-style-blink=false
adjust-cell-height = 10%

# Tabs
keybind = cmd+[=previous_tab
keybind = cmd+]=next_tab
keybind = cmd+,=previous_tab
keybind = cmd+.=next_tab

# Splits
keybind = cmd+down=goto_split:down
keybind = cmd+left=goto_split:left
keybind = cmd+up=goto_split:up
keybind = cmd+right=goto_split:right
keybind = cmd+shift+up=resize_split:up,20
keybind = cmd+shift+down=resize_split:down,20
keybind = cmd+shift+left=resize_split:left,20
keybind = cmd+shift+right=resize_split:right,20
keybind = cmd+s=toggle_split_zoom

keybind = shift+enter=text:\x1b\r

# Tmux Suppprt
keybind = cmd+digit_1=csi:49;9u
keybind = cmd+digit_2=csi:50;9u
keybind = cmd+digit_3=csi:51;9u
keybind = cmd+digit_4=csi:52;9u
keybind = cmd+digit_5=csi:53;9u
keybind = cmd+digit_6=csi:54;9u
keybind = cmd+digit_7=csi:55;9u
keybind = cmd+digit_8=csi:56;9u
keybind = cmd+digit_9=csi:57;9u
keybind = cmd+digit_0=csi:48;9u

