let mapleader=" "
let maplocalleader=" "

set relativenumber
set scrolloff=5
set incsearch
set hlsearch
set ignorecase
set smartcase
set clipboard=unnamedplus,unnamed,ideaput
set showmode
set timeoutlen=400
set multiple-cursors
set surround
set commentary
set argtextobj
set textobj-entire

inoremap jk <esc>
inoremap kj <esc>
inoremap <C-c> <esc>

nnoremap Q gq

nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

nnoremap n nzz
nnoremap N Nzz

nnoremap L $
nnoremap H ^

nnoremap <silent> <CR> :nohlsearch<CR><CR>

" IDE actions should always be mapped using map
nmap <leader><leader> :action GotoFile<CR>
nmap <leader>o :action GotoClass<CR>
nmap <leader>O :action GotoSymbol<CR>
nmap <leader>r :action Run<CR>
nmap <leader>d :action Debug<CR>
nmap grn :action RenameElement<CR>
nmap grr :action ShowUsages<CR>
nmap gd :action GotoDeclaration<CR>
nmap gri :action GotoImplementation<CR>
nmap <leader>g :action Annotate<CR>
