    "foreground": "#1f2328",
    "descriptionForeground": "#6e7781",
    "errorForeground": "#cf222e",
    "icon.foreground": "#6e7781",
    "textLink.foreground": "#0550ae",
    "textLink.activeForeground": "#0969da",
    "textPreformat.foreground": "#0a3069",
    "textSeparator.foreground": "#d0d7de",

    "editor.background": "#ffffff",
    "editor.foreground": "#1f2328",
    "editorLineNumber.foreground": "#8c959f",
    "editorLineNumber.activeForeground": "#cf222e",
    "editorCursor.foreground": "#1f2328",
    "editor.selectionBackground": "#dddddd",
    "editor.inactiveSelectionBackground": "#eaeef2",
    "editor.selectionHighlightBackground": "#dddddd80",
    "editor.wordHighlightBackground": "#dddddd66",
    "editor.wordHighlightStrongBackground": "#dddddd99",
    "editor.findMatchBackground": "#fff8c566",
