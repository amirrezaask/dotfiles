    "gitDecoration.untrackedResourceForeground": "#7ee787",
    "gitDecoration.ignoredResourceForeground": "#484f58"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8b949e", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#7ee787" }
    },
    {
      "scope": ["string.regexp", "constant.character.escape"],
      "settings": { "foreground": "#a5d6ff" }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "scope": ["constant", "entity.name.constant", "variable.other.constant", "variable.other.enummember", "variable.language"],
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control", "keyword.operator.word"],
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "scope": ["storage.modifier.import", "storage.modifier.package"],
      "settings": { "foreground": "#e6edf3" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "storage.type.primitive"],
      "settings": { "foreground": "#ffa657" }
    },
    {
      "scope": ["entity.name", "meta.definition.variable", "variable"],
      "settings": { "foreground": "#ffa657" }
    },
    {
      "scope": ["variable.other", "variable.parameter", "meta.jsx.children"],
      "settings": { "foreground": "#e6edf3" }
    },
    {
      "scope": ["variable.other.member", "variable.other.property", "meta.property-name", "support.variable.property"],
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#7ee787" }
    },
    {
      "scope": ["support.class.component"],
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "scope": ["punctuation", "keyword.operator"],
      "settings": { "foreground": "#e6edf3" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#79c0ff", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#a5d6ff", "fontStyle": "underline" }
    },
    {
      "scope": ["markup.raw", "markup.inline.raw"],
      "settings": { "foreground": "#7ee787" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#7ee787" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ff7b72" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#ffa657" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ffa198" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "keyword": "#ff7b72",
    "function": "#d2a8ff",
    "method": "#d2a8ff",
    "string": "#7ee787",
    "number": "#79c0ff",
    "type": "#ffa657",
    "class": "#ffa657",
    "interface": "#ffa657",
    "enum": "#ffa657",
    "enumMember": "#79c0ff",
    "variable": "#ffa657",
    "parameter": "#e6edf3",
    "property": "#79c0ff",
    "namespace": "#79c0ff",
    "macro": "#d2a8ff",
    "comment": "#8b949e"
  }
}
