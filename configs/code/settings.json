{
  "editor.fontFamily": "Maple Mono, Jetbrains Mono",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.5,
  "editor.cursorBlinking": "solid",
  "files.autoSave": "onFocusChange",
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.mouseWheelScrollSensitivity": 2,
  "window.restoreWindows": "none",
  "workbench.settings.editor": "json",
  "terminal.integrated.macOptionIsMeta": true,
  "workbench.editor.enablePreview": false,
  "window.title": "${rootName}${separator}${profileName}",
  "files.simpleDialog.enable": true,
  "[go]": { "editor.formatOnSave": true },
  "explorer.confirmDelete": false,
  "workbench.startupEditor": "none",
  "editor.bracketPairColorization.enabled": false,
  "gitProjectManager.baseProjectsFolders": ["~/dev" ],
  "gitProjectManager.openInNewWindow": true,
  "git.blame.statusBarItem.enabled": true,
  "terminal.integrated.fontSize": 16,
  "extensions.ignoreRecommendations": true,
  "window.nativeTabs": true,
  "go.toolsManagement.autoUpdate": true,
  "window.commandCenter": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "kilo-code.debug": false,
  "kilo-code.allowedCommands": [
    "git log",
    "git diff",
    "git show"
  ],
  "kilo-code.deniedCommands": [],
  "redhat.telemetry.enabled": true,
  "window.autoDetectColorScheme": false,
  "workbench.preferredLightColorTheme": "Light 2026",
  "workbench.preferredDarkColorTheme": "Dark 2026",
  "terminal.integrated.commandsToSkipShell": [
    "kilo-code.new.agentManagerOpen",
    "kilo-code.new.agentManager.showTerminal"
  ],
  "workbench.activityBar.location": "top",
  "window.customTitleBarVisibility": "never",
  "workbench.editor.showTabs": "none",
  "workbench.statusBar.visible": false,
}
