{
  "breadcrumbs.enabled": false,
  "editor.fontFamily": "JetBrains Mono",
  "editor.fontSize": 14,
  "editor.cursorBlinking": "smooth",
  "editor.stickyScroll.enabled": false,
  "files.autoSave": "onFocusChange",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.glyphMargin": false,
  "editor.minimap.enabled": false,
  "window.restoreWindows": "none",
  "workbench.settings.editor": "json",
  "terminal.integrated.macOptionIsMeta": true,
  "editor.lineNumbers": "off",
  "workbench.editor.enablePreview": false,
  "window.title": "${rootName} ${seperator} ${activeEditorMedium}",
  "window.titleBarStyle": "custom",
  "window.customTitleBarVisibility": "windowed",
  "files.simpleDialog.enable": true,
  "[go]": { "editor.formatOnSave": true },
  "explorer.confirmDelete": false,
  "workbench.startupEditor": "none",
  "editor.bracketPairColorization.enabled": false,
  "git.blame.statusBarItem.enabled": true,
  "terminal.integrated.fontSize": 16,
  "extensions.ignoreRecommendations": true,
  "go.toolsManagement.autoUpdate": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "redhat.telemetry.enabled": true,
  "window.autoDetectColorScheme": true,
  "workbench.preferredLightColorTheme": "Light 2026",
  "workbench.preferredDarkColorTheme": "Dark 2026",
  "workbench.browser.showInTitleBar": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.navigationControl.enabled": false,
  "workbench.editor.editorActionsLocation": "hidden",
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,
  "[typescript]": { 
    "editor.formatOnSave": true,
    "editor.indentSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.formatOnSave": true,
    "editor.indentSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.maxTokenizationLineLength": 2500,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Vscode <3 Vim
  "vim.foldfix": true,
  "vim.leader": " ",
  "vim.useSystemClipboard": true,
  "vim.timeout": 200,
  "vim.normalModeKeyBindings": [
    { "before": ["<C-d>"], "after": ["<C-d>", "z", "z"] },
    { "before": ["<C-u>"], "after": ["<C-u>", "z", "z"] },
    { "before": [ "<leader>", "<leader>" ], "commands": ["workbench.action.quickOpen"], },
    { "before": [ "<leader>", "o" ], "commands": ["workbench.action.gotoSymbol"], },
    { "before": [ "<leader>", "O" ], "commands": ["workbench.action.showAllSymbols"], },
    { "before": [ "g", "r" ], "commands": [ "references-view.findReferences" ], },
    { "before": [ "g", "l" ], "commands": [ "editor.action.showHover" ], },
    { "before": [ "K" ], "commands": [ "editor.action.showHover" ], },
    { "before": [ "[", "d" ], "commands": [ "editor.action.marker.prev" ], },
    { "before": [ "]", "d" ], "commands": [ "editor.action.marker.next" ], },
    { "before": [ "C"], "commands": [ "editor.action.quickFix" ] },
    { "before": [ "R" ], "commands": [ "editor.action.rename" ] },
    { "before": ["{"], "commands": [ "references-view.prev"] },
    { "before": ["}"], "commands": [ "references-view.next"] },
    { "before": ["j"], "after": ["g", "j"]},
    { "before": ["k"], "after": ["g", "k"]}
  ],
  "vim.insertModeKeyBindings": [
    { "before": [ "j", "k" ], "after": [ "<esc>" ] },
    { "before": [ "k", "j" ], "after": [ "<esc>" ] },
    { "before": [ "<c-w" ],   "commands": [ "editor.deleteWord"] },
  ],
  "git.openRepositoryInParentFolders": "never",
  "workbench.activityBar.location": "top",
  "cursor.composer.shouldChimeAfterChatFinishes": true,
}
