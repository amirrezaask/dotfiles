#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KITTY_CONF="$DOTFILES_DIR/configs/kitty/kitty.conf"
KITTY_THEMES_DIR="$DOTFILES_DIR/configs/kitty/themes"
GHOSTTY_CONF="$DOTFILES_DIR/configs/ghostty/config"
GHOSTTY_THEMES_DIR="$DOTFILES_DIR/configs/ghostty/themes"
NVIM_INIT="$DOTFILES_DIR/configs/nvim/init.lua"

# Format: kitty_theme:nvim_colorscheme:ghostty_theme
# ghostty_theme: empty = use kitty name; "builtin:<name>" = built-in; otherwise path in themes/
# ghostty theme names from: ghostty +list-themes --plain
Themes=(
  "Catppuccin-Mocha:catppuccin-nvim:Catppuccin Mocha"
  "Catppuccin-Latte:catppuccin-nvim:Catppuccin Latte"
  "Catppuccin-Macchiato:catppuccin-nvim:Catppuccin Macchiato"
  "Catppuccin-Frappe:catppuccin-nvim:Catppuccin Frappe"
  "gruvbox-dark:gruvbox:Gruvbox Dark"
  "everforest_dark_hard:everforest:Everforest Dark Hard"
  "everforest_dark_medium:everforest:Everforest Dark Hard"
  "rose-pine:rose-pine:Rose Pine"
  "rose-pine-moon:rose-pine:Rose Pine Moon"
  "rose-pine-dawn:rose-pine:Rose Pine Dawn"
  "tokyo_night_night:tokyonight-night:TokyoNight Night"
  "tokyo_night_day:tokyonight:TokyoNight Day"
  "tokyo_night_storm:tokyonight:TokyoNight Storm"
  "tokyo_night_moon:tokyonight:TokyoNight Moon"
  "OneDark:onedark:Atom One Dark"
  "OneDark-Pro:onedark:One Dark Two"
  "Cyberdream:cyberdream:cyberdream"
  "Vague:vague:Vague"
  "vercel:vercel:"
  "vercel-light:vercel:"
)

KITTY_THEME="${1:-}"
NVIM_THEME="${2:-}"
GHOSTTY_THEME=""

# Usage / fzf
usage() {
  echo "Usage: $(basename "$0") [kitty-theme] [nvim-colorscheme]"
  echo ""
  echo "No args -> fzf picker from Themes array"
  echo "1 arg  -> auto-map nvim + ghostty"
  echo "2 args -> explicit kitty + nvim, ghostty auto-map"
  exit 1
}

if [ -z "$KITTY_THEME" ]; then
  if ! command -v fzf &>/dev/null; then
    echo "Error: no args given and fzf not found"
    usage
  fi

  SELECTED=$(
    for pair in "${Themes[@]}"; do
      IFS=: read -r k n g <<< "$pair"
      printf "%-40s %-20s %s\n" "$k" "$n" "$g"
    done | fzf --header="kitty-theme                            nvim-colorscheme      ghostty" \
               --with-nth=1 --preview='echo {}' | awk '{print $1}'
  )

  [ -z "$SELECTED" ] && { echo "No theme selected"; exit 1; }
  KITTY_THEME="$SELECTED"
fi

# Resolve nvim + ghostty from Themes array
for pair in "${Themes[@]}"; do
  IFS=: read -r k n g <<< "$pair"
  if [ "$k" = "$KITTY_THEME" ]; then
    [ -z "$NVIM_THEME" ] && NVIM_THEME="$n"
    [ -z "$GHOSTTY_THEME" ] && GHOSTTY_THEME="$g"
    break
  fi
done

# Auto-map nvim if still empty
if [ -z "$NVIM_THEME" ]; then
  case "$KITTY_THEME" in
    Catppuccin-*)          NVIM_THEME="catppuccin-nvim" ;;
    gruvbox*)              NVIM_THEME="gruvbox" ;;
    everforest*)           NVIM_THEME="everforest" ;;
    rose-pine*)            NVIM_THEME="rose-pine" ;;
    tokyo*|Tokyo*)         NVIM_THEME="tokyonight" ;;
    onedark*|OneDark*)     NVIM_THEME="onedark" ;;
    cyberdream*|Cyberdream*) NVIM_THEME="cyberdream" ;;
    adwaita*)              NVIM_THEME="adwaita" ;;
    evergarden*)           NVIM_THEME="evergarden" ;;
    vague*)                NVIM_THEME="vague" ;;
    *)                     NVIM_THEME="catppuccin-nvim" ;;
  esac
fi

# Auto-map ghostty if not in array
if [ -z "$GHOSTTY_THEME" ]; then
  # use lowercase-hyphenated kitty name as ghostty built-in name
  GHOSTTY_THEME=$(echo "$KITTY_THEME" | tr '[:upper:]' '[:lower:]' | tr '_' '-' | tr ' ' '-')
fi

# --- Validate kitty theme ---
THEME_FILE="$KITTY_THEMES_DIR/$KITTY_THEME.conf"
if [ ! -f "$THEME_FILE" ]; then
  echo "Error: kitty theme '$KITTY_THEME' not found in themes/"
  ls "$KITTY_THEMES_DIR"/*.conf 2>/dev/null | sed 's/.*\///; s/\.conf$//' | sort
  exit 1
fi

# --- Kitty ---
rm -f "$DOTFILES_DIR/configs/kitty/dark-theme.auto.conf" \
     "$DOTFILES_DIR/configs/kitty/light-theme.auto.conf"

INCLUDE_LINE="include themes/$KITTY_THEME.conf"
if grep -q "^include themes/" "$KITTY_CONF"; then
  sed -i '' "s|^include themes/.*|$INCLUDE_LINE|" "$KITTY_CONF"
else
  printf "\n# Theme\n%s\n" "$INCLUDE_LINE" >> "$KITTY_CONF"
fi

echo "Kitty: $KITTY_THEME"

# --- Ghostty ---
if [ -f "$GHOSTTY_THEMES_DIR/$GHOSTTY_THEME" ]; then
  GHOSTTY_VAL="$GHOSTTY_THEMES_DIR/$GHOSTTY_THEME"
  echo "Ghostty: $GHOSTTY_THEME (custom file)"
elif grep -qi "^theme = " "$GHOSTTY_CONF" 2>/dev/null; then
  GHOSTTY_VAL="$GHOSTTY_THEME"
fi

if grep -qi "^theme = " "$GHOSTTY_CONF" 2>/dev/null; then
  sed -i '' "s|^theme = .*|theme = $GHOSTTY_VAL|I" "$GHOSTTY_CONF"
else
  echo "theme = $GHOSTTY_VAL" >> "$GHOSTTY_CONF"
fi

echo "Ghostty: $GHOSTTY_VAL"


sed -i '' "s|vim.g.colorscheme = os.getenv(\"NVIM_THEME\") or \"[^\"]*\"|vim.g.colorscheme = os.getenv(\"NVIM_THEME\") or \"$NVIM_THEME\"|" "$NVIM_INIT"
echo "Neovim: $NVIM_THEME"
